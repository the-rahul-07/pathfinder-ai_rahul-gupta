# Inngest (Background Job Processing)
# Used by generateIndustryInsights and other background functions.
# Without these, background jobs will silently never fire.
# Get both keys from: https://app.inngest.com → your app → Manage
# For local dev, set both to: local  (then run: npx inngest-cli@latest dev)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key