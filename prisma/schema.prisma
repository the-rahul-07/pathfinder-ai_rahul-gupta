  createdAt      DateTime @default(now())

  @@index([userId])
}

model CareerBreakPlan {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration       String
  reason         String   @db.Text
  returnGoals    String   @db.Text
  planData       Json
  createdAt      DateTime @default(now())

  @@index([userId])
}