generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Database Indexing Strategy
// =============================================================================
//
// Composite indexes support common filter + sort query patterns. For example:
//   - Message: [conversationId, createdAt] — fetch messages for a chat ordered by time
//   - Conversation: [userId, updatedAt] — list a user's conversations by recency
//
// In PostgreSQL, @unique and @@unique constraints automatically create B-tree indexes.
// Do NOT add a separate @@index on the same column(s) — it duplicates storage and
// slows writes with no query benefit.
//
// Single-column indexes are kept alongside composites when they serve different
// query shapes (e.g. simple WHERE without ORDER BY, or deleteMany by userId).
// =============================================================================

model User {
  id              String           @id @default(uuid())
  clerkUserId     String           @unique
  email           String           @unique
  name            String?
  imageUrl        String?
  industry        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Profile fields
  currentRole     String?
  targetRole      String?
  careerGoals     String?
  bio             String?
  experience      Int?
  
  // Settings
  saveChatHistory Boolean          @default(true)

  // Relations
  skills          String[]
  assessments     Assessment[]
  coverLetter     CoverLetter[]
  conversations   Conversation[]
  resume          Resume?
  industryInsight IndustryInsight? @relation(fields: [industry], references: [industry])
  atsAnalyses          ATSAnalysis[]
  roadmaps             Roadmap[]
  jobApplications      JobApplication[]
  linkedinOptimizations LinkedInOptimization[]
  networkingEmails     NetworkingEmail[]
  projectIdeas         ProjectIdea[]
  resumeGenerations    ResumeGeneration[]
  starStories          StarStory[]
  recruiterEmails      RecruiterEmail[]
  interviewCheatSheets InterviewCheatSheet[]
  linkedinPosts        LinkedInPost[]
  offerComparisons     OfferComparison[]
  careerPivots         CareerPivot[]
  onboardingPlans      OnboardingPlan[]
  resignationLetters   ResignationLetter[]
  promotionStrategies  PromotionStrategy[]
  freelanceProposals   FreelanceProposal[]
  behavioralPreps      BehavioralPrep[]
  layoffStrategies     LayoffStrategy[]
  coffeeChatSessions   CoffeeChatSession[]
  equityAnalyses       EquityAnalysis[]
  assignmentGrades     AssignmentGrade[]
  burnoutAssessments   BurnoutAssessment[]
  sideHustleIdeas      SideHustleIdea[]
  remoteWorkPitches    RemoteWorkPitch[]
  internalTransfers    InternalTransfer[]
  careerBreakPlans     CareerBreakPlan[]
  settings             UserSettings?

  exportRecords ExportRecord[]
  auditLogs     AuditLog[]
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  quizScore      Float
  questions      Json[]
  category       String
  improvementTip String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Resume {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  atsScore  Float?
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobApplications JobApplication[]

  @@index([userId])
}

// industry @unique already creates a B-tree index for lookups (findUnique/upsert by industry).
// A separate @@index([industry]) was removed — it duplicated the unique constraint index.
model IndustryInsight {
  id                String   @id @default(cuid())
  industry          String   @unique
  users             User[]
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       String
  topSkills         String[]
  marketOutlook     String
  keyTrends         String[]
  recommendedSkills String[]
  isGrounded        Boolean  @default(false)
  lastUpdated       DateTime @default(now())
  nextUpdate        DateTime
}

// @@index([userId]) — simple user lookups and deleteMany without ordering.
// @@index([userId, updatedAt]) — list/search conversations filtered by user, ordered by recency.
model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  type      String    @default("chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
  @@index([userId, updatedAt])
  exports   ExportRecord[]
  snapshots ConversationSnapshot[]
}

// @@index([conversationId]) — simple message lookups without ordering.
// @@index([conversationId, createdAt]) — fetch messages for a conversation ordered by time.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model ATSAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  resumeContent   String   @db.Text
  jobDescription  String   @db.Text
  jobTitle        String?
  companyName     String?
  atsScore        Float
  matchedKeywords String[]
  missingKeywords String[]
  suggestions     Json[]
  overallFeedback String?  @db.Text
  createdAt       DateTime @default(now())
  jobApplications JobApplication[]

  @@index([userId])
}

model ExportRecord {
  id             String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  format         String
  status         String @default("completed")
  downloadCount  Int @default(0)

  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
}

model ConversationSnapshot {
  id             String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  title          String
  version        Int

  data           Json

  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model AuditLog {
  id           String @id @default(cuid())

  userId       String
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action       String
  resourceType String
  resourceId   String

  metadata     Json?

  createdAt    DateTime @default(now())

  @@index([userId])
}


model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  theme           String   @default("light")
  notifications   Boolean  @default(true)
  emailAlerts     Boolean  @default(true)
  dashboardLayout String   @default("default")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// @@unique([userId, action, windowStart]) — exact-window upsert/lookup (rate-limit hot path).
// @@index([userId, action]) — broader scans by user + action. No changes needed.
model AiRateLimit {
  id        String   @id @default(cuid())
  userId    String
  action    String
  windowStart DateTime
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, action, windowStart])
  @@index([userId, action])
}

model Roadmap {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Json     // The full roadmap milestones JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobApplication {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  jobTitle       String
  status         String       @default("Wishlist")
  url            String?
  salary         String?
  location       String?
  notes          String?      @db.Text
  atsAnalysisId  String?
  atsAnalysis    ATSAnalysis? @relation(fields: [atsAnalysisId], references: [id], onDelete: SetNull)
  coverLetterId  String?
  coverLetter    CoverLetter? @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)
  interviewDate  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
}

model LinkedInOptimization {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileContent String   @db.Text
  analysis       Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model NetworkingEmail {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName  String?
  company        String?
  goal           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
}

model ProjectIdea {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole     String
  skillGap       String
  ideas          Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model ResumeGeneration {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobDescription String   @db.Text
  content        Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model StarStory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawExperience  String   @db.Text
  starContent    Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model RecruiterEmail {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalEmail  String   @db.Text
  goal           String
  replyContent   String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
}

model InterviewCheatSheet {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        String
  role           String
  content        Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model LinkedInPost {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          String   @db.Text
  content        Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model OfferComparison {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers         Json
  analysis       Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model CareerPivot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRole    String
  targetRole     String
  analysis       Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model OnboardingPlan {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        String
  role           String
  planContent    Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model ResignationLetter {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  circumstance   String
  lastDay        String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
}

model PromotionStrategy {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole     String
  content        Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model FreelanceProposal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectDetails String   @db.Text
  rate           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
}

model BehavioralPrep {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        String
  assessmentType String
  content        Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model LayoffStrategy {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  details        String   @db.Text
