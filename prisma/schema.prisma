  @@index([userId])
}

model CoffeeChatSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole     String
  industry       String
  chatHistory    Json
  feedback       Json?
  createdAt      DateTime @default(now())

  @@index([userId])
}

model EquityAnalysis {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerDetails   Json
  analysis       Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model AssignmentGrade {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt         String   @db.Text
  solution       String   @db.Text
  gradeData      Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model BurnoutAssessment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptoms       String   @db.Text
  workload       String   @db.Text
  assessment     Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model SideHustleIdea {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         String   @db.Text
  interests      String   @db.Text
  ideasData      Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model RemoteWorkPitch {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  reasons        String   @db.Text
  objections     String   @db.Text
  pitchData      Json
  createdAt      DateTime @default(now())

  @@index([userId])
}

model InternalTransfer {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRole    String
  targetRole     String
  reasons        String   @db.Text
